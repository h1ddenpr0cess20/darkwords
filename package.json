{
  "name": "darkwords",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "A dark, editorial chat client for the Anthropic API and local models",
  "author": "Dustin Whyte",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/h1ddenpr0cess20/darkwords.git"
  },
  "homepage": "https://github.com/h1ddenpr0cess20/darkwords#readme",
  "bugs": "https://github.com/h1ddenpr0cess20/darkwords/issues",
  "keywords": [
    "anthropic",
    "claude",
    "lm-studio",
    "chat",
    "react",
    "vite"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit && biome check .",
    "test": "vitest run",
    "format": "biome format --write ."
